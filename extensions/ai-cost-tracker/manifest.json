{
  "manifest_version": 3,
  "name": "AI Cost Tracker",
  "description": "Estimate AI usage costs by project while you work.",
  "version": "0.3.4",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://*.claude.ai/*",
    "https://firefly.adobe.com/*",
    "https://fal.ai/*",
    "https://*.fal.ai/*",
    "https://gemini.google.com/*",
    "https://flow.google/*",
    "https://labs.google/fx/tools/flow*",
    "https://canva.com/*",
    "https://www.canva.com/*",
    "https://midjourney.com/*",
    "https://www.midjourney.com/*",
    "https://runwayml.com/*",
    "https://app.runwayml.com/*",
    "https://meta.ai/*",
    "https://www.meta.ai/*",
    "https://ai.meta.com/*"
  ],
  "action": {
    "default_title": "AI Cost Tracker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*",
        "https://firefly.adobe.com/*",
        "https://fal.ai/*",
        "https://*.fal.ai/*",
        "https://gemini.google.com/*",
        "https://flow.google/*",
        "https://labs.google/fx/tools/flow*",
        "https://canva.com/*",
        "https://www.canva.com/*",
        "https://midjourney.com/*",
        "https://www.midjourney.com/*",
        "https://runwayml.com/*",
        "https://app.runwayml.com/*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://ai.meta.com/*"
      ],
      "js": ["provider-config.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
